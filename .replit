modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5601
externalPort = 3002

[[ports]]
localPort = 5602
externalPort = 3003

[[ports]]
localPort = 5603
externalPort = 4200

[[ports]]
localPort = 24678
externalPort = 3000

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "billing-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "billing-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx server/billing.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[agent]
integrations = ["javascript_stripe:1.0.0", "javascript_database:1.0.0", "resend:1.0.0", "javascript_object_storage:1.0.0"]

[userenv]

[userenv.production]
DEMO_SEED = "true"
APP_BASE_URL = "https://unihub.live"

[userenv.shared]
APPLE_WALLET_PASS_TYPE_ID = "pass.live.unihub.loyalty"
APPLE_WALLET_TEAM_ID = "782KA53BM3"
ADMIN_SEED_EMAIL = "antonispleipell@gmail.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
